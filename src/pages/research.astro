---
import Layout from "@/layouts/Layout.astro";
---
<Layout title="账号运营数据 | Fon">
  <div class="prose max-w-none">

    <h1 class="text-3xl font-bold mb-2">账号运营数据</h1>
    <p class="text-base opacity-60 mb-10">Social Media Operations & Performance Data</p>

    <!-- 小红书总览 -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-1 border-b pb-2">📱 小红书 · Xiaohongshu</h2>
      <p class="text-sm opacity-50 mb-6">账号内容运营数据概览 · Account Performance Overview</p>

      <div class="not-prose grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">4.8w+</div>
          <div class="text-sm font-medium mt-1">笔记总赞评</div>
          <div class="text-xs opacity-50 mt-0.5">Total Likes & Comments</div>
        </div>
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">3篇</div>
          <div class="text-sm font-medium mt-1">浏览量 10w+</div>
          <div class="text-xs opacity-50 mt-0.5">Posts over 100K Views</div>
        </div>
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">12篇</div>
          <div class="text-sm font-medium mt-1">浏览量 1w+</div>
          <div class="text-xs opacity-50 mt-0.5">Posts over 10K Views</div>
        </div>
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">1篇</div>
          <div class="text-sm font-medium mt-1">赞藏 5000+</div>
          <div class="text-xs opacity-50 mt-0.5">Post with 5K+ Saves</div>
        </div>
      </div>

      <!-- 浏览量分布 -->
      <div class="not-prose mb-8">
        <h3 class="text-base font-bold mb-4">浏览量分布 · Views Breakdown</h3>
        <div class="space-y-3">
          <div class="flex items-center gap-4">
            <span class="text-sm w-24 shrink-0">10w+ 浏览</span>
            <div class="flex-1 bg-base-200 rounded-full h-4">
              <div class="bg-accent h-4 rounded-full" style="width: 25%"></div>
            </div>
            <span class="text-sm font-bold w-8 text-right">3</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm w-24 shrink-0">5w+ 浏览</span>
            <div class="flex-1 bg-base-200 rounded-full h-4">
              <div class="bg-secondary h-4 rounded-full" style="width: 8%"></div>
            </div>
            <span class="text-sm font-bold w-8 text-right">1</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm w-24 shrink-0">1w+ 浏览</span>
            <div class="flex-1 bg-base-200 rounded-full h-4">
              <div class="bg-primary h-4 rounded-full" style="width: 100%"></div>
            </div>
            <span class="text-sm font-bold w-8 text-right">12</span>
          </div>
        </div>
      </div>

      <!-- 赞藏分布 -->
      <div class="not-prose mb-8">
        <h3 class="text-base font-bold mb-4">赞藏分布 · Likes & Saves Breakdown</h3>
        <div class="space-y-3">
          <div class="flex items-center gap-4">
            <span class="text-sm w-24 shrink-0">5000+ 赞藏</span>
            <div class="flex-1 bg-base-200 rounded-full h-4">
              <div class="bg-primary h-4 rounded-full" style="width: 7%"></div>
            </div>
            <span class="text-sm font-bold w-8 text-right">1</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm w-24 shrink-0">4000+ 赞藏</span>
            <div class="flex-1 bg-base-200 rounded-full h-4">
              <div class="bg-primary h-4 rounded-full" style="width: 7%"></div>
            </div>
            <span class="text-sm font-bold w-8 text-right">1</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm w-24 shrink-0">1000+ 赞藏</span>
            <div class="flex-1 bg-base-200 rounded-full h-4">
              <div class="bg-primary h-4 rounded-full" style="width: 14%"></div>
            </div>
            <span class="text-sm font-bold w-8 text-right">2</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm w-24 shrink-0">500+ 赞藏</span>
            <div class="flex-1 bg-base-200 rounded-full h-4">
              <div class="bg-primary h-4 rounded-full" style="width: 100%"></div>
            </div>
            <span class="text-sm font-bold w-8 text-right">14</span>
          </div>
        </div>
      </div>

      <div class="not-prose">
        <a href="https://xhslink.com/m/1JIYxGNlQx" target="_blank" class="btn btn-outline btn-sm">
          查看小红书主页 →
        </a>
      </div>
    </section>

    <!-- 公众号 -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-1 border-b pb-2">📰 微信公众号 · WeChat Official Account</h2>
      <p class="text-sm opacity-50 mb-6">内容创作与运营数据 · Content Creation & Operations</p>
      <div class="not-prose grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">100+</div>
          <div class="text-sm font-medium mt-1">累计推文篇数</div>
          <div class="text-xs opacity-50 mt-0.5">Articles Published</div>
        </div>
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">20+</div>
          <div class="text-sm font-medium mt-1">视频内容条数</div>
          <div class="text-xs opacity-50 mt-0.5">Videos Produced</div>
        </div>
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">30%</div>
          <div class="text-sm font-medium mt-1">曝光量增长</div>
          <div class="text-xs opacity-50 mt-0.5">Exposure Growth</div>
        </div>
      </div>
    </section>

    <!-- 社群运营 -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-1 border-b pb-2">👥 社群运营 · Community Management</h2>
      <p class="text-sm opacity-50 mb-6">粉丝社群管理与用户增长数据</p>
      <div class="not-prose grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">5个</div>
          <div class="text-sm font-medium mt-1">核心粉丝社群</div>
          <div class="text-xs opacity-50 mt-0.5">Fan Communities</div>
        </div>
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">2000+</div>
          <div class="text-sm font-medium mt-1">社群总人数</div>
          <div class="text-xs opacity-50 mt-0.5">Total Members</div>
        </div>
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">55%</div>
          <div class="text-sm font-medium mt-1">社群活跃度提升</div>
          <div class="text-xs opacity-50 mt-0.5">Engagement Increase</div>
        </div>
        <div class="border rounded-xl p-4 text-center">
          <div class="text-2xl font-bold">12%</div>
          <div class="text-sm font-medium mt-1">活动转化率</div>
          <div class="text-xs opacity-50 mt-0.5">Event Conversion Rate</div>
        </div>
      </div>
    </section>

  </div>
</Layout>
